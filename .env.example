# ⚠️ Çok satırlı JSON'u doğrudan .env içine yapıştırmayın (dotenv sadece ilk satırı okur).
#
# --- Vercel (Production / Preview) ---
# Sadece GOOGLE_SERVICE_ACCOUNT_JSON kullanın (Base64 veya tek satır JSON).
# GOOGLE_SERVICE_ACCOUNT_JSON_FILE Vercel'de çalışmaz; boş bırakın veya hiç tanımlamayın.
#
# --- Yerel geliştirme ---
# JSON dosyası (secrets/ .gitignore'da):
# GOOGLE_SERVICE_ACCOUNT_JSON_FILE=secrets/sa.json
#
# Veya Base64 / tek satır JSON:
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_FILE=

# E-tablo: https://docs.google.com/spreadsheets/d/BU_KISIM/edit (Drive /folders/... değil)
GOOGLE_SPREADSHEET_ID=11szwdIz_kAn-QTqVHJjmaUKBzf2BOVAWT1mx7Z66G8E

SHEET_MEDIA_NAME=Medya
SHEET_TASKS_NAME=Görevler
SHEET_WORK_NAME=İş
SHEET_FINANS_NAME=Finans

# CRM (Google Sheets sekmeleri; dosyada bu adlarla sayfa oluşturun)
SHEET_CRM_LEADS_NAME=CRM_Leads
SHEET_CRM_TEMPLATES_NAME=CRM_Sablonlar

# İsteğe bağlı: kendi Overpass / Nominatim örneğiniz
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# NOMINATIM_API_URL=https://nominatim.openstreetmap.org
